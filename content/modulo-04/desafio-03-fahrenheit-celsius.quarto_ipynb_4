   "metadata": {},
   "outputs": [],
   "source": [
    "#| eval: false\n",
    "# Desafío 3: Conversor Fahrenheit ↔ Celsius\n",
    "# Solución de referencia\n",
    "\n",
    "def celsius_a_fahrenheit(celsius):\n",
    "    \"\"\"Convierte grados Celsius a Fahrenheit.\"\"\"\n",
    "    return celsius * 9/5 + 32\n",
    "\n",
    "def fahrenheit_a_celsius(fahrenheit):\n",
    "    \"\"\"Convierte grados Fahrenheit a Celsius.\"\"\"\n",
    "    return (fahrenheit - 32) * 5/9\n",
    "\n",
    "# Pruebas con valores conocidos\n",
    "print(f\"0°C = {celsius_a_fahrenheit(0):.1f}°F\")\n",
    "print(f\"100°C = {celsius_a_fahrenheit(100):.1f}°F\")\n",
    "print(f\"98.6°F = {fahrenheit_a_celsius(98.6):.1f}°C\")\n",
    "print(f\"32°F = {fahrenheit_a_celsius(32):.1f}°C\")\n",
    "\n",
    "# Verificación: convertir y volver debe dar el mismo valor\n",
    "original = 25\n",
    "convertido = celsius_a_fahrenheit(original)\n",
    "de_vuelta = fahrenheit_a_celsius(convertido)\n",
    "print(f\"\\nVerificación: {original}°C → {convertido:.1f}°F → {de_vuelta:.1f}°C\")"
   ]
