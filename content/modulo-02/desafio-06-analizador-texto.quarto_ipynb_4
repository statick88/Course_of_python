   "metadata": {},
   "outputs": [],
   "source": [
    "#| eval: false\n",
    "# Desafío 6: Analizador de texto\n",
    "# Solución de referencia\n",
    "\n",
    "print(\"=== ANALIZADOR DE TEXTO ===\")\n",
    "print()\n",
    "\n",
    "# <1> Pedir texto\n",
    "texto = input(\"Ingresa un texto: \").strip()\n",
    "\n",
    "if not texto:\n",
    "    print(\"✗ El texto está vacío. Ingresa algo para analizar.\")\n",
    "else:\n",
    "    # <2> Contar caracteres\n",
    "    total_caracteres = len(texto)\n",
    "    sin_espacios = total_caracteres - texto.count(\" \")\n",
    "    \n",
    "    # <3> Contar palabras\n",
    "    palabras = texto.split()\n",
    "    total_palabras = len(palabras)\n",
    "    \n",
    "    # <4> Contar oraciones\n",
    "    oraciones = texto.count(\".\") + texto.count(\"!\") + texto.count(\"?\")\n",
    "    if oraciones == 0:\n",
    "        oraciones = 1  # Si no hay puntuación, es una oración\n",
    "    \n",
    "    # <5> Letra más frecuente\n",
    "    letras_solo = [c.lower() for c in texto if c.isalpha()]\n",
    "    if letras_solo:\n",
    "        letra_mas_frecuente = max(set(letras_solo), key=letras_solo.count)\n",
    "        frecuencia = letras_solo.count(letra_mas_frecuente)\n",
    "    else:\n",
    "        letra_mas_frecuente = \"N/A\"\n",
    "        frecuencia = 0\n",
    "    \n",
    "    # <6> Porcentaje de vocales\n",
    "    vocales = \"aeiouáéíóú\"\n",
    "    total_vocales = sum(1 for c in letras_solo if c.lower() in vocales)\n",
    "    total_letras = len(letras_solo)\n",
    "    porcentaje_vocales = round((total_vocales / total_letras * 100), 1) if total_letras > 0 else 0\n",
    "    \n",
    "    # <7> Palabra más larga\n",
    "    palabra_larga = max(palabras, key=len)\n",
    "    \n",
    "    # <8> Mostrar resultados\n",
    "    print()\n",
    "    print(\"--- Análisis ---\")\n",
    "    print(f\"Caracteres totales: {total_caracteres}\")\n",
    "    print(f\"Caracteres (sin espacios): {sin_espacios}\")\n",
    "    print(f\"Palabras: {total_palabras}\")\n",
    "    print(f\"Oraciones: {oraciones}\")\n",
    "    print(f\"Letra más frecuente: '{letra_mas_frecuente}' ({frecuencia} veces)\")\n",
    "    print(f\"Porcentaje de vocales: {porcentaje_vocales}%\")\n",
    "    print(f\"Palabra más larga: '{palabra_larga}' ({len(palabra_larga)} letras)\")"
   ]
