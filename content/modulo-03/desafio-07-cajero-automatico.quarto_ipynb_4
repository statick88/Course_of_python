    "#| eval: false\n",
    "# Desafío 7: Cajero automático\n",
    "# Solución de referencia\n",
    "\n",
    "print(\"=== CAJERO AUTOMÁTICO ===\")\n",
    "print(\"Bienvenido, usuario\\n\")\n",
    "\n",
    "saldo = 1000.00\n",
    "historial = [{\"tipo\": \"Inicial\", \"monto\": 0, \"saldo\": saldo}]\n",
    "\n",
    "while True:\n",
    "    print(f\"\\nSaldo actual: ${saldo:,.2f}\")\n",
    "    print()\n",
    "    print(\"1. Consultar saldo\")\n",
    "    print(\"2. Depositar\")\n",
    "    print(\"3. Retirar\")\n",
    "    print(\"4. Historial\")\n",
    "    print(\"5. Salir\")\n",
    "    \n",
    "    opcion = input(\"\\nElige una opción: \").strip()\n",
    "    \n",
    "    if opcion == \"1\":\n",
    "        print(f\"\\n💰 Tu saldo es: ${saldo:,.2f}\")\n",
    "    \n",
    "    elif opcion == \"2\":\n",
    "        while True:\n",
    "            monto_str = input(\"\\n¿Cuánto deseas depositar? $\")\n",
    "            if monto_str.replace(\".\", \"\").isdigit():\n",
    "                monto = float(monto_str)\n",
    "                if monto > 0:\n",
    "                    break\n",
    "            print(\"⚠️ Ingresa un monto válido mayor a 0.\")\n",
    "        \n",
    "        saldo = saldo + monto\n",
    "        historial.append({\"tipo\": \"Depósito\", \"monto\": monto, \"saldo\": saldo})\n",
    "        print(f\"✅ Depósito exitoso: ${monto:,.2f}\")\n",
    "        print(f\"Saldo actual: ${saldo:,.2f}\")\n",
    "    \n",
    "    elif opcion == \"3\":\n",
    "        while True:\n",
    "            monto_str = input(\"\\n¿Cuánto deseas retirar? $\")\n",
    "            if monto_str.replace(\".\", \"\").isdigit():\n",
    "                monto = float(monto_str)\n",
    "                if monto > 0:\n",
    "                    if monto <= saldo:\n",
    "                        break\n",
    "                    print(f\"⚠️ Saldo insuficiente. Tu saldo es: ${saldo:,.2f}\")\n",
    "                else:\n",
    "                    print(\"⚠️ Ingresa un monto mayor a 0.\")\n",
    "            else:\n",
    "                print(\"⚠️ Ingresa un monto válido.\")\n",
    "        \n",
    "        saldo = saldo - monto\n",
    "        historial.append({\"tipo\": \"Retiro\", \"monto\": monto, \"saldo\": saldo})\n",
    "        print(f\"✅ Retiro exitoso: ${monto:,.2f}\")\n",
    "        print(f\"Saldo actual: ${saldo:,.2f}\")\n",
    "    \n",
    "    elif opcion == \"4\":\n",
    "        print(\"\\n=== HISTORIAL DE TRANSACCIONES ===\")\n",
    "        for i, transaccion in enumerate(historial):\n",
    "            tipo = transaccion[\"tipo\"]\n",
    "            monto = transaccion[\"monto\"]\n",
    "            saldo_hist = transaccion[\"saldo\"]\n",
    "            \n",
    "            if monto > 0:\n",
    "                if tipo == \"Depósito\":\n",
    "                    monto_str = f\"+${monto:,.2f}\"\n",
    "                else:\n",
    "                    monto_str = f\"-${monto:,.2f}\"\n",
    "            else:\n",
    "                monto_str = \"\"\n",
    "            \n",
    "            print(f\"#{i:<3} | {tipo:<10} | {monto_str:>10} | Saldo: ${saldo_hist:,.2f}\")\n",
    "    \n",
    "    elif opcion == \"5\":\n",
    "        print(\"\\n¡Gracias por usar nuestro cajero!\")\n",
    "        break\n",
    "    \n",
    "    else:\n",
    "        print(\"⚠️ Opción no válida. Elige 1-5.\")"
   ]
