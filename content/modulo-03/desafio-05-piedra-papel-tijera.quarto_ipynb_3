   "source": [
    "#| eval: false\n",
    "# Desafío 5: Piedra, papel o tijera\n",
    "# Solución de referencia\n",
    "\n",
    "import random\n",
    "\n",
    "print(\"=== PIEDRA, PAPEL O TIJERA ===\")\n",
    "print(\"Primero en ganar 3 rondas\\n\")\n",
    "\n",
    "opciones = [\"piedra\", \"papel\", \"tijera\"]\n",
    "victorias_jugador = 0\n",
    "victorias_cpu = 0\n",
    "ronda = 0\n",
    "\n",
    "while victorias_jugador < 3 and victorias_cpu < 3:\n",
    "    ronda = ronda + 1\n",
    "    print(f\"--- Ronda {ronda} ---\")\n",
    "    \n",
    "    jugador = input(\"Tu elección (piedra/papel/tijera): \").lower().strip()\n",
    "    \n",
    "    if jugador not in opciones:\n",
    "        print(\"⚠️ Opción no válida. Elige piedra, papel o tijera.\\n\")\n",
    "        continue\n",
    "    \n",
    "    cpu = random.choice(opciones)\n",
    "    \n",
    "    print(f\"Computadora: {cpu}\")\n",
    "    \n",
    "    if jugador == cpu:\n",
    "        print(\"🤝 ¡Empate!\")\n",
    "    elif (jugador == \"piedra\" and cpu == \"tijera\") or \\\n",
    "         (jugador == \"papel\" and cpu == \"piedra\") or \\\n",
    "         (jugador == \"tijera\" and cpu == \"papel\"):\n",
    "        print(\"🎉 ¡Ganaste esta ronda!\")\n",
    "        victorias_jugador = victorias_jugador + 1\n",
    "    else:\n",
    "        print(\"😔 La computadora gana esta ronda\")\n",
    "        victorias_cpu = victorias_cpu + 1\n",
    "    \n",
    "    print(f\"\\nMarcador: Tú {victorias_jugador} - {victorias_cpu} Computadora\\n\")\n",
    "\n",
    "if victorias_jugador == 3:\n",
    "    print(f\"🏆 ¡GANASTE! Marcador final: {victorias_jugador} - {victorias_cpu}\")\n",
    "else:\n",
    "    print(f\"💻 La computadora gana. Marcador final: {victorias_jugador} - {victorias_cpu}\")"
   ]
