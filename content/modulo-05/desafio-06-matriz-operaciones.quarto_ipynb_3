   "source": [
    "#| eval: false\n",
    "# Desafío 6: Operaciones con matrices\n",
    "# Solución de referencia\n",
    "\n",
    "# Tablero: G=Guerrero, A=Arquero, S=Soldado, .=Vacío\n",
    "tablero = [ # <1>\n",
    "    [\"G\", \"A\", \"S\", \".\", \".\"],\n",
    "    [\".\", \"G\", \"A\", \"S\", \".\"],\n",
    "    [\".\", \".\", \"G\", \"A\", \"S\"],\n",
    "    [\".\", \".\", \".\", \".\", \".\"],\n",
    "    [\".\", \".\", \".\", \".\", \".\"],\n",
    "]\n",
    "\n",
    "poderes = {\"G\": 100, \"A\": 80, \"S\": 50, \".\": 0} # <2>\n",
    "nombres = {\"G\": \"Guerrero\", \"A\": \"Arquero\", \"S\": \"Soldado\"}\n",
    "\n",
    "# Mostrar tablero\n",
    "print(\"⚔️ Tablero de Estrategia\")\n",
    "print()\n",
    "print(\"Tablero:\")\n",
    "for fila in tablero: # <3>\n",
    "    print(f\"  [{'  '.join(fila)}]\") # <4>\n",
    "\n",
    "# Contar unidades\n",
    "conteo = {tipo: 0 for tipo in poderes} # <5>\n",
    "for fila in tablero: # <6>\n",
    "    for celda in fila:\n",
    "        if celda in conteo:\n",
    "            conteo[celda] += 1\n",
    "\n",
    "print()\n",
    "print(\"📊 Resumen del ejército:\")\n",
    "for tipo, nombre in nombres.items(): # <7>\n",
    "    print(f\"  {nombre}s ({tipo}): {conteo[tipo]}\")\n",
    "print(f\"  Vacíos (.): {conteo['.']}\")\n",
    "\n",
    "# Poder total y unidad más fuerte\n",
    "poder_total = 0 # <8>\n",
    "max_poder = 0\n",
    "max_pos = (0, 0)\n",
    "\n",
    "for i, fila in enumerate(tablero): # <9>\n",
    "    for j, celda in enumerate(fila):\n",
    "        poder = poderes.get(celda, 0) # <10>\n",
    "        poder_total += poder\n",
    "        if poder > max_poder: # <11>\n",
    "            max_poder = poder\n",
    "            max_pos = (i, j)\n",
    "            max_tipo = celda\n",
    "\n",
    "print()\n",
    "print(f\"💪 Poder total del ejército: {poder_total}\")\n",
    "print(f\"🏆 Unidad más fuerte: {nombres[max_tipo]} en posición [{max_pos[0]}][{max_pos[1]}] con poder {max_poder}\")"
   ]
  },
  {
   "cell_type": "markdown",
