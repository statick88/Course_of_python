        "#| eval: false\n",
        "\"\"\"Módulo de gestión de estudiantes.\n",
        "\n",
        "Proporciona funciones para cargar, procesar y guardar\n",
        "datos de estudiantes desde archivos CSV.\n",
        "\n",
        "Funciones principales:\n",
        "    - cargar_estudiantes: Lee estudiantes desde un archivo CSV.\n",
        "    - obtener_aprobados: Filtra estudiantes con nota >= 15.\n",
        "    - calcular_promedio: Calcula el promedio general de notas.\n",
        "    - guardar_estudiantes: Guarda estudiantes en archivo CSV.\n",
        "\"\"\"\n",
        "\n",
        "from typing import List, Dict\n",
        "import os\n",
        "\n",
        "\n",
        "class ErrorDeArchivo(Exception):\n",
        "    \"\"\"Error al leer o escribir archivos de estudiantes.\"\"\"\n",
        "    pass\n",
        "\n",
        "\n",
        "def cargar_estudiantes(ruta_archivo: str) -> List[Dict]:\n",
        "    \"\"\"Carga la lista de estudiantes desde un archivo CSV.\n",
        "    \n",
        "    El archivo debe tener el formato: nombre,nota (una línea por estudiante).\n",
        "    \n",
        "    Args:\n",
        "        ruta_archivo: Ruta del archivo CSV a cargar.\n",
        "    \n",
        "    Returns:\n",
        "        Lista de diccionarios con claves 'nombre' y 'nota'.\n",
        "    \n",
        "    Raises:\n",
        "        ErrorDeArchivo: Si el archivo no existe o tiene formato inválido.\n",
        "    \"\"\"\n",
        "    if not os.path.exists(ruta_archivo):\n",
        "        raise ErrorDeArchivo(f\"El archivo '{ruta_archivo}' no existe\")\n",
        "    \n",
        "    estudiantes = []\n",
        "    with open(ruta_archivo, \"r\") as archivo:\n",
        "        for linea in archivo:\n",
        "            linea = linea.strip()\n",
        "            if not linea:\n",
        "                continue\n",
        "            partes = linea.split(\",\")\n",
        "            if len(partes) != 2:\n",
        "                raise ErrorDeArchivo(\n",
        "                    f\"Línea con formato inválido: '{linea}'\"\n",
        "                )\n",
        "            try:\n",
        "                nota = int(partes[1])\n",
        "            except ValueError:\n",
        "                raise ErrorDeArchivo(\n",
        "                    f\"Nota no válida en línea: '{linea}'\"\n",
        "                )\n",
        "            estudiantes.append({\n",
        "                \"nombre\": partes[0],\n",
        "                \"nota\": nota\n",
        "            })\n",
        "    return estudiantes\n",
        "\n",
        "\n",
        "def obtener_aprobados(estudiantes: List[Dict], nota_minima: int = 15) -> List[str]:\n",
        "    \"\"\"Obtiene los nombres de los estudiantes aprobados.\n",
        "    \n",
        "    Función pura: misma entrada → misma salida.\n",
        "    \n",
        "    Args:\n",
        "        estudiantes: Lista de diccionarios con datos de estudiantes.\n",
        "        nota_minima: Nota mínima para aprobar. Por defecto 15.\n",
        "    \n",
        "    Returns:\n",
        "        Lista de nombres de estudiantes aprobados.\n",
        "    \"\"\"\n",
        "    return [\n",
        "        estudiante[\"nombre\"]\n",
        "        for estudiante in estudiantes\n",
        "        if estudiante[\"nota\"] >= nota_minima\n",
        "    ]\n",
        "\n",
        "\n",
        "def calcular_promedio(estudiantes: List[Dict]) -> float:\n",
        "    \"\"\"Calcula el promedio de notas de los estudiantes.\n",
        "    \n",
        "    Función pura: misma entrada → misma salida.\n",
        "    \n",
        "    Args:\n",
        "        estudiantes: Lista de diccionarios con datos de estudiantes.\n",
        "    \n",
        "    Returns:\n",
        "        El promedio de notas como número flotante.\n",
        "    \n",
        "    Raises:\n",
        "        ValueError: Si la lista de estudiantes está vacía.\n",
        "    \"\"\"\n",
        "    if not estudiantes:\n",
        "        raise ValueError(\"No se puede calcular promedio de lista vacía\")\n",
        "    \n",
        "    suma_notas = sum(estudiante[\"nota\"] for estudiante in estudiantes)\n",
        "    return suma_notas / len(estudiantes)\n",
        "\n",
        "\n",
        "def guardar_estudiantes(estudiantes: List[Dict], ruta_archivo: str) -> None:\n",
        "    \"\"\"Guarda la lista de estudiantes en un archivo CSV.\n",
        "    \n",
        "    Args:\n",
        "        estudiantes: Lista de diccionarios con datos de estudiantes.\n",
        "        ruta_archivo: Ruta del archivo donde se guardarán los datos.\n",
        "    \"\"\"\n",
        "    with open(ruta_archivo, \"w\") as archivo:\n",
        "        for estudiante in estudiantes:\n",
        "            archivo.write(\n",
        "                f\"{estudiante['nombre']},{estudiante['nota']}\\n\"\n",
        "            )\n",
        "\n",
        "\n",
        "# Ejemplo de uso\n",
        "if __name__ == \"__main__\":\n",
        "    try:\n",
        "        lista_estudiantes = cargar_estudiantes(\"estudiantes.csv\")\n",
        "        \n",
        "        aprobados = obtener_aprobados(lista_estudiantes)\n",
        "        promedio = calcular_promedio(lista_estudiantes)\n",
        "        \n",
        "        guardar_estudiantes(lista_estudiantes, \"estudiantes_backup.csv\")\n",
        "        \n",
        "        print(f\"Aprobados: {aprobados}\")\n",
        "        print(f\"Promedio: {promedio:.2f}\")\n",
        "    except ErrorDeArchivo as e:\n",
        "        print(f\"Error de archivo: {e}\")\n",
        "    except ValueError as e:\n",
        "        print(f\"Error de datos: {e}\")"
