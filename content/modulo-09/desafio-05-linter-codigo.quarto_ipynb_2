        "#| eval: false\n",
        "# Desafío 5: Corregir errores de linter\n",
        "# Solución de referencia\n",
        "\n",
        "import json\n",
        "import os\n",
        "from datetime import datetime\n",
        "\n",
        "MAX_INTENTOS = 3\n",
        "API_URL = \"https://api.ejemplo.com\"\n",
        "\n",
        "\n",
        "def obtener_datos(url, timeout=5, retries=MAX_INTENTOS):\n",
        "    \"\"\"Obtiene datos de una URL con reintentos.\n",
        "    \n",
        "    Args:\n",
        "        url: La URL de la cual obtener datos.\n",
        "        timeout: Tiempo máximo de espera en segundos.\n",
        "        retries: Número máximo de intentos.\n",
        "    \n",
        "    Returns:\n",
        "        Lista con los datos obtenidos.\n",
        "    \"\"\"\n",
        "    datos = []\n",
        "    for i in range(retries):\n",
        "        try:\n",
        "            resultado = procesar_solicitud(url, timeout)\n",
        "            if resultado:\n",
        "                datos.append(resultado)\n",
        "                break\n",
        "        except Exception:\n",
        "            if i == retries - 1:\n",
        "                print(f\"Error después de {retries} intentos\")\n",
        "    return datos\n",
        "\n",
        "\n",
        "def procesar_solicitud(url, timeout):\n",
        "    \"\"\"Procesa una solicitud a la URL dada.\n",
        "    \n",
        "    Args:\n",
        "        url: La URL de la solicitud.\n",
        "        timeout: Tiempo máximo de espera.\n",
        "    \n",
        "    Returns:\n",
        "        Diccionario con los datos de la respuesta.\n",
        "    \"\"\"\n",
        "    resultado = {\n",
        "        \"url\": url,\n",
        "        \"timestamp\": str(datetime.now()),\n",
        "        \"status\": \"ok\"\n",
        "    }\n",
        "    return resultado\n",
        "\n",
        "\n",
        "class GestorDatos:\n",
        "    \"\"\"Gestiona una colección de datos con caché.\n",
        "    \n",
        "    Attributes:\n",
        "        datos: Lista de diccionarios con los datos.\n",
        "        _cache: Diccionario de caché para búsquedas rápidas.\n",
        "    \"\"\"\n",
        "    \n",
        "    def __init__(self, datos):\n",
        "        \"\"\"Inicializa el gestor con una lista de datos.\"\"\"\n",
        "        self.datos = datos\n",
        "        self._cache = {}\n",
        "    \n",
        "    def buscar(self, clave):\n",
        "        \"\"\"Busca un dato por su clave, usando caché si está disponible.\n",
        "        \n",
        "        Args:\n",
        "            clave: La clave a buscar en los datos.\n",
        "        \n",
        "        Returns:\n",
        "            El diccionario encontrado o None si no existe.\n",
        "        \"\"\"\n",
        "        if clave in self._cache:\n",
        "            return self._cache[clave]\n",
        "        for item in self.datos:\n",
        "            if item.get(\"clave\") == clave:\n",
        "                self._cache[clave] = item\n",
        "                return item\n",
        "        return None\n",
        "    \n",
        "    def agregar(self, item):\n",
        "        \"\"\"Agrega un nuevo dato e invalida la caché.\n",
        "        \n",
        "        Args:\n",
        "            item: Diccionario con el nuevo dato a agregar.\n",
        "        \"\"\"\n",
        "        self.datos.append(item)\n",
        "        self._cache = {}"
