        "#| eval: false\n",
        "# Desafío 2: Documentar funciones con docstrings\n",
        "# Solución de referencia\n",
        "\n",
        "def calcular_area_circulo(radio: float) -> float:\n",
        "    \"\"\"Calcula el área de un círculo dado su radio.\n",
        "    \n",
        "    Usa la fórmula: área = π × radio²\n",
        "    \n",
        "    Args:\n",
        "        radio: El radio del círculo en unidades de longitud.\n",
        "            Debe ser un número positivo.\n",
        "    \n",
        "    Returns:\n",
        "        El área del círculo en unidades cuadradas.\n",
        "    \n",
        "    Examples:\n",
        "        >>> calcular_area_circulo(1)\n",
        "        3.14159\n",
        "        >>> calcular_area_circulo(5)\n",
        "        78.53975\n",
        "    \"\"\"\n",
        "    return 3.14159 * radio ** 2\n",
        "\n",
        "\n",
        "def convertir_temperatura(celsius: float) -> float:\n",
        "    \"\"\"Convierte una temperatura de Celsius a Fahrenheit.\n",
        "    \n",
        "    Usa la fórmula: F = (C × 9/5) + 32\n",
        "    \n",
        "    Args:\n",
        "        celsius: La temperatura en grados Celsius.\n",
        "            Puede ser negativa (temperaturas bajo cero).\n",
        "    \n",
        "    Returns:\n",
        "        La temperatura equivalente en grados Fahrenheit.\n",
        "    \n",
        "    Examples:\n",
        "        >>> convertir_temperatura(0)\n",
        "        32.0\n",
        "        >>> convertir_temperatura(100)\n",
        "        212.0\n",
        "        >>> convertir_temperatura(-40)\n",
        "        -40.0\n",
        "    \"\"\"\n",
        "    return (celsius * 9/5) + 32\n",
        "\n",
        "\n",
        "def encontrar_maximo(lista: list) -> int:\n",
        "    \"\"\"Encuentra el valor máximo en una lista de números.\n",
        "    \n",
        "    Recorre la lista comparando cada elemento con el máximo\n",
        "    encontrado hasta el momento.\n",
        "    \n",
        "    Args:\n",
        "        lista: Lista de números (enteros o flotantes).\n",
        "            No puede estar vacía.\n",
        "    \n",
        "    Returns:\n",
        "        El valor más grande de la lista.\n",
        "    \n",
        "    Raises:\n",
        "        ValueError: Si la lista está vacía.\n",
        "    \n",
        "    Examples:\n",
        "        >>> encontrar_maximo([1, 5, 3, 9, 2])\n",
        "        9\n",
        "        >>> encontrar_maximo([-10, -5, -3])\n",
        "        -3\n",
        "    \"\"\"\n",
        "    if not lista:\n",
        "        raise ValueError(\"La lista no puede estar vacía\")\n",
        "    maximo = lista[0]\n",
        "    for numero in lista:\n",
        "        if numero > maximo:\n",
        "            maximo = numero\n",
        "    return maximo"
