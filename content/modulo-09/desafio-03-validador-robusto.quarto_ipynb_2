        "#| eval: false\n",
        "# Desafío 3: Validador de datos robusto\n",
        "# Solución de referencia\n",
        "\n",
        "def validar_email(email: str) -> bool:\n",
        "    \"\"\"Verifica que un email tenga un formato válido.\n",
        "    \n",
        "    Args:\n",
        "        email: La dirección de email a validar.\n",
        "    \n",
        "    Returns:\n",
        "        True si el email tiene formato válido, False en caso contrario.\n",
        "    \"\"\"\n",
        "    if not email or \" \" in email:\n",
        "        return False\n",
        "    \n",
        "    if \"@\" not in email:\n",
        "        return False\n",
        "    \n",
        "    partes = email.split(\"@\")\n",
        "    if len(partes) != 2:\n",
        "        return False\n",
        "    \n",
        "    dominio = partes[1]\n",
        "    return \".\" in dominio and len(dominio) > 2\n",
        "\n",
        "\n",
        "def validar_password(password: str) -> tuple:\n",
        "    \"\"\"Verifica que una contraseña cumpla los requisitos de seguridad.\n",
        "    \n",
        "    Args:\n",
        "        password: La contraseña a validar.\n",
        "    \n",
        "    Returns:\n",
        "        Tupla (es_valida, mensaje). Si es válida, mensaje es vacío.\n",
        "    \"\"\"\n",
        "    if len(password) < 8:\n",
        "        return (False, \"La contraseña debe tener al menos 8 caracteres\")\n",
        "    \n",
        "    if not any(c.isupper() for c in password):\n",
        "        return (False, \"La contraseña debe tener al menos una mayúscula\")\n",
        "    \n",
        "    if not any(c.isdigit() for c in password):\n",
        "        return (False, \"La contraseña debe tener al menos un número\")\n",
        "    \n",
        "    return (True, \"\")\n",
        "\n",
        "\n",
        "def validar_edad(edad: str) -> int:\n",
        "    \"\"\"Convierte y valida una edad como número entero.\n",
        "    \n",
        "    Args:\n",
        "        edad: La edad como string a convertir y validar.\n",
        "    \n",
        "    Returns:\n",
        "        La edad como número entero.\n",
        "    \n",
        "    Raises:\n",
        "        ValueError: Si la edad no es un número o está fuera del rango 0-150.\n",
        "    \"\"\"\n",
        "    try:\n",
        "        edad_numero = int(edad)\n",
        "    except ValueError:\n",
        "        raise ValueError(f\"'{edad}' no es un número válido\")\n",
        "    \n",
        "    if edad_numero < 0:\n",
        "        raise ValueError(f\"La edad no puede ser negativa: {edad_numero}\")\n",
        "    \n",
        "    if edad_numero > 150:\n",
        "        raise ValueError(f\"La edad no puede ser mayor a 150: {edad_numero}\")\n",
        "    \n",
        "    return edad_numero\n",
        "\n",
        "\n",
        "def validar_usuario(email: str, password: str, edad: str) -> dict:\n",
        "    \"\"\"Valida todos los campos de registro de un usuario.\n",
        "    \n",
        "    Args:\n",
        "        email: Dirección de email del usuario.\n",
        "        password: Contraseña elegida por el usuario.\n",
        "        edad: Edad del usuario como string.\n",
        "    \n",
        "    Returns:\n",
        "        Diccionario con 'valido' (bool) y 'datos' o 'errores'.\n",
        "    \"\"\"\n",
        "    errores = []\n",
        "    \n",
        "    if not validar_email(email):\n",
        "        errores.append(\"Email no válido\")\n",
        "    \n",
        "    password_valida, mensaje = validar_password(password)\n",
        "    if not password_valida:\n",
        "        errores.append(mensaje)\n",
        "    \n",
        "    try:\n",
        "        edad_validada = validar_edad(edad)\n",
        "    except ValueError as e:\n",
        "        errores.append(str(e))\n",
        "        edad_validada = None\n",
        "    \n",
        "    if errores:\n",
        "        return {\"valido\": False, \"errores\": errores}\n",
        "    \n",
        "    return {\n",
        "        \"valido\": True,\n",
        "        \"datos\": {\n",
        "            \"email\": email,\n",
        "            \"edad\": edad_validada\n",
        "        }\n",
        "    }\n",
        "\n",
        "\n",
        "# Ejemplo de uso\n",
        "resultado = validar_usuario(\"ana@ejemplo.com\", \"MiPass123\", \"25\")\n",
        "print(resultado)\n",
        "# {'valido': True, 'datos': {'email': 'ana@ejemplo.com', 'edad': 25}}\n",
        "\n",
        "resultado_error = validar_usuario(\"ana\", \"muy corta\", \"abc\")\n",
        "print(resultado_error)\n",
        "# {'valido': False, 'errores': ['Email no válido', 'La contraseña debe tener al menos 8 caracteres', \"'abc' no es un número válido\"]}"
