        "#| eval: false\n",
        "# Desafío 4: Tests para calculadora\n",
        "# Solución de referencia\n",
        "\n",
        "import pytest\n",
        "\n",
        "# --- Funciones de la calculadora ---\n",
        "\n",
        "def sumar(a: float, b: float) -> float:\n",
        "    \"\"\"Suma dos números.\"\"\"\n",
        "    return a + b\n",
        "\n",
        "def restar(a: float, b: float) -> float:\n",
        "    \"\"\"Resta b de a.\"\"\"\n",
        "    return a - b\n",
        "\n",
        "def multiplicar(a: float, b: float) -> float:\n",
        "    \"\"\"Multiplica dos números.\"\"\"\n",
        "    return a * b\n",
        "\n",
        "def dividir(a: float, b: float) -> float:\n",
        "    \"\"\"Divide a entre b.\"\"\"\n",
        "    if b == 0:\n",
        "        raise ValueError(\"No se puede dividir por cero\")\n",
        "    return a / b\n",
        "\n",
        "def potencia(base: float, exponente: float) -> float:\n",
        "    \"\"\"Calcula base elevado a exponente.\"\"\"\n",
        "    return base ** exponente\n",
        "\n",
        "\n",
        "# --- Tests ---\n",
        "\n",
        "def test_sumar_dos_positivos_devuelve_suma():\n",
        "    assert sumar(2, 3) == 5\n",
        "\n",
        "def test_sumar_con_negativo():\n",
        "    assert sumar(5, -3) == 2\n",
        "\n",
        "def test_sumar_ceros():\n",
        "    assert sumar(0, 0) == 0\n",
        "\n",
        "def test_restar_positivos():\n",
        "    assert restar(10, 4) == 6\n",
        "\n",
        "def test_restar_resultado_negativo():\n",
        "    assert restar(3, 7) == -4\n",
        "\n",
        "def test_multiplicar_positivos():\n",
        "    assert multiplicar(3, 4) == 12\n",
        "\n",
        "def test_multiplicar_por_cero():\n",
        "    assert multiplicar(5, 0) == 0\n",
        "\n",
        "def test_multiplicar_negativos():\n",
        "    assert multiplicar(-3, -4) == 12\n",
        "\n",
        "def test_dividir_exacta():\n",
        "    assert dividir(10, 2) == 5.0\n",
        "\n",
        "def test_dividir_por_cero_lanza_error():\n",
        "    with pytest.raises(ValueError):\n",
        "        dividir(10, 0)\n",
        "\n",
        "def test_dividir_con_decimales():\n",
        "    assert dividir(7, 2) == 3.5\n",
        "\n",
        "def test_potencia_entera():\n",
        "    assert potencia(2, 3) == 8\n",
        "\n",
        "def test_potencia_cero():\n",
        "    assert potencia(5, 0) == 1\n",
        "\n",
        "# Tests parametrizados\n",
        "\n",
        "@pytest.mark.parametrize(\"a, b, esperado\", [\n",
        "    (1, 1, 2),\n",
        "    (0, 5, 5),\n",
        "    (-1, -1, -2),\n",
        "    (100, 200, 300),\n",
        "    (1.5, 2.5, 4.0),\n",
        "])\n",
        "def test_sumar_parametrizado(a, b, esperado):\n",
        "    assert sumar(a, b) == esperado\n",
        "\n",
        "\n",
        "@pytest.mark.parametrize(\"base, exponente, esperado\", [\n",
        "    (2, 0, 1),\n",
        "    (2, 1, 2),\n",
        "    (2, 3, 8),\n",
        "    (10, 2, 100),\n",
        "    (5, -1, 0.2),\n",
        "])\n",
        "def test_potencia_parametrizado(base, exponente, esperado):\n",
        "    assert potencia(base, exponente) == esperado"
      ],
