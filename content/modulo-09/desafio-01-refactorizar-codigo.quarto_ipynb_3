    "#| eval: false\n",
    "# Desafío 1: Refactorizar código desordenado\n",
    "# Solución de referencia\n",
    "\n",
    "def es_primo(numero: int) -> bool:\n",
    "    \"\"\"Verifica si un número es primo.\n",
    "    \n",
    "    Un número primo es mayor que 1 y solo es divisible\n",
    "    entre 1 y sí mismo.\n",
    "    \n",
    "    Args:\n",
    "        numero: El número a verificar.\n",
    "    \n",
    "    Returns:\n",
    "        True si el número es primo, False en caso contrario.\n",
    "    \"\"\"\n",
    "    cantidad_divisores = 0\n",
    "    \n",
    "    for divisor in range(1, numero + 1):\n",
    "        if numero % divisor == 0:\n",
    "            cantidad_divisores += 1\n",
    "    \n",
    "    return cantidad_divisores == 2\n",
    "\n",
    "\n",
    "# Verificar si 17 es primo\n",
    "resultado = es_primo(17)\n",
    "print(f\"¿17 es primo? {resultado}\")"
