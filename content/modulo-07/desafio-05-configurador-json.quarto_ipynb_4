   "source": [
    "#| eval: false\n",
    "# Desafío 5: Configurador JSON\n",
    "# Solución de referencia\n",
    "\n",
    "import json\n",
    "import os\n",
    "\n",
    "CONFIG_FILE = \"app_config.json\"\n",
    "\n",
    "# Configuración por defecto\n",
    "CONFIG_DEFAULT = {\n",
    "    \"app_name\": \"Mi Aplicación\",\n",
    "    \"version\": \"1.0.0\",\n",
    "    \"theme\": \"dark\",\n",
    "    \"language\": \"es\",\n",
    "    \"notifications\": True,\n",
    "    \"max_conexiones\": 100,\n",
    "}\n",
    "\n",
    "def cargar_configuracion():\n",
    "    \"\"\"Carga configuración desde archivo o usa valores por defecto.\"\"\"\n",
    "    if os.path.exists(CONFIG_FILE):\n",
    "        try:\n",
    "            with open(CONFIG_FILE, \"r\") as f:\n",
    "                return json.load(f)\n",
    "        except json.JSONDecodeError:\n",
    "            print(\"⚠️ Archivo corrupto, usando configuración por defecto\")\n",
    "    return CONFIG_DEFAULT.copy()\n",
    "\n",
    "def guardar_configuracion(config):\n",
    "    \"\"\"Guarda la configuración en archivo JSON.\"\"\"\n",
    "    with open(CONFIG_FILE, \"w\") as f:\n",
    "        json.dump(config, f, indent=4, ensure_ascii=False)\n",
    "\n",
    "def mostrar_configuracion(config):\n",
    "    \"\"\"Muestra la configuración actual de forma legible.\"\"\"\n",
    "    print(\"\\n📋 Configuración actual:\")\n",
    "    for clave, valor in config.items():\n",
    "        print(f\"  {clave}: {valor}\")\n",
    "    print()\n",
    "\n",
    "# Programa principal\n",
    "print(\"⚙️ === CONFIGURADOR DE APP ===\\n\")\n",
    "\n",
    "config = cargar_configuracion()\n",
    "mostrar_configuracion(config)\n",
    "\n",
    "while True:\n",
    "    clave = input(\"¿Qué configuración quieres cambiar? (o 'salir'): \").strip()\n",
    "    \n",
    "    if clave.lower() == \"salir\":\n",
    "        break\n",
    "    \n",
    "    if clave not in config:\n",
    "        print(f\"❌ '{clave}' no es una configuración válida\")\n",
    "        print(f\"   Claves disponibles: {', '.join(config.keys())}\")\n",
    "        continue\n",
    "    \n",
    "    valor_actual = config[clave]\n",
    "    nuevo_valor = input(f\"Nuevo valor para '{clave}' (actual: {valor_actual}): \").strip()\n",
    "    \n",
    "    # Intentar convertir al tipo original\n",
    "    if isinstance(valor_actual, bool):\n",
    "        config[clave] = nuevo_valor.lower() in (\"true\", \"si\", \"sí\", \"1\", \"yes\")\n",
    "    elif isinstance(valor_actual, int):\n",
    "        try:\n",
    "            config[clave] = int(nuevo_valor)\n",
    "        except ValueError:\n",
    "            print(f\"❌ '{nuevo_valor}' no es un número entero válido\")\n",
    "            continue\n",
    "    elif isinstance(valor_actual, float):\n",
    "        try:\n",
    "            config[clave] = float(nuevo_valor)\n",
    "        except ValueError:\n",
    "            print(f\"❌ '{nuevo_valor}' no es un número válido\")\n",
    "            continue\n",
    "    else:\n",
    "        config[clave] = nuevo_valor\n",
    "    \n",
    "    print(f\"✅ Configuración actualizada: {clave} = {config[clave]}\")\n",
    "\n",
    "print(\"\\n💾 Guardando configuración...\")\n",
    "guardar_configuracion(config)\n",
    "print(f\"✅ Configuración guardada en {CONFIG_FILE}\")"
   ]
