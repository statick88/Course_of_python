      "source": [
        "#| eval: false\n",
        "# Desafío 3: Log Analyzer\n",
        "# Solución de referencia\n",
        "\n",
        "from pathlib import Path\n",
        "\n",
        "# Paso 1: Generar archivo de log de prueba\n",
        "LOG_FILE = \"servidor.log\"\n",
        "\n",
        "entradas_log = [\n",
        "    \"[2026-04-04 10:15:23] INFO Servidor iniciado correctamente\",\n",
        "    \"[2026-04-04 10:15:45] INFO Usuario conectado: ana\",\n",
        "    \"[2026-04-04 10:16:02] WARNING Espacio en disco al 85%\",\n",
        "    \"[2026-04-04 10:16:30] ERROR No se pudo conectar a la base de datos\",\n",
        "    \"[2026-04-04 10:17:00] CRITICAL Sistema de pagos fuera de línea\",\n",
        "    \"[2026-04-04 10:17:15] INFO Petición GET /api/usuarios procesada\",\n",
        "    \"[2026-04-04 10:17:30] WARNING Tiempo de respuesta alto: 2.5s\",\n",
        "    \"[2026-04-04 10:18:00] INFO Backup automático completado\",\n",
        "    \"[2026-04-04 10:18:30] ERROR Timeout en servicio de autenticación\",\n",
        "    \"[2026-04-04 10:19:00] INFO Usuario desconectado: ana\",\n",
        "    \"[2026-04-04 10:19:30] INFO Usuario conectado: carlos\",\n",
        "    \"[2026-04-04 10:20:00] WARNING Memoria RAM al 90%\",\n",
        "    \"[2026-04-04 10:20:30] ERROR Archivo de configuración corrupto\",\n",
        "    \"[2026-04-04 10:21:00] INFO Servicio reiniciado correctamente\",\n",
        "    \"[2026-04-04 10:21:30] INFO Todas las verificaciones pasaron\",\n",
        "]\n",
        "\n",
        "with open(LOG_FILE, \"w\") as f:\n",
        "    for entrada in entradas_log:\n",
        "        f.write(entrada + \"\\n\")\n",
        "\n",
        "print(f\"📝 Archivo de log generado: {LOG_FILE}\\n\")\n",
        "\n",
        "# Paso 2: Analizar el log\n",
        "print(\"🔍 === LOG ANALYZER ===\\n\")\n",
        "\n",
        "contador = {\"INFO\": 0, \"WARNING\": 0, \"ERROR\": 0, \"CRITICAL\": 0}\n",
        "entradas_criticas = []\n",
        "total = 0\n",
        "\n",
        "with open(LOG_FILE, \"r\") as f:\n",
        "    for linea in f:\n",
        "        linea = linea.strip()\n",
        "        if not linea:\n",
        "            continue\n",
        "        \n",
        "        total += 1\n",
        "        \n",
        "        for nivel in contador:\n",
        "            if f\"] {nivel} \" in linea:\n",
        "                contador[nivel] += 1\n",
        "                if nivel in (\"ERROR\", \"CRITICAL\"):\n",
        "                    entradas_criticas.append(linea)\n",
        "                break\n",
        "\n",
        "# Paso 3: Mostrar resultados\n",
        "print(\"📊 Resumen de severidad:\")\n",
        "for nivel, cantidad in contador.items():\n",
        "    icono = {\"INFO\": \"✅\", \"WARNING\": \"⚠️\", \"ERROR\": \"❌\", \"CRITICAL\": \"🔴\"}\n",
        "    print(f\"  {icono[nivel]} {nivel:<10} {cantidad}\")\n",
        "\n",
        "if entradas_criticas:\n",
        "    print(f\"\\n⚠️ Entradas críticas encontradas:\")\n",
        "    for entrada in entradas_criticas:\n",
        "        print(f\"  {entrada}\")\n",
        "\n",
        "print(f\"\\n📈 Total de entradas: {total}\")"
      ],
