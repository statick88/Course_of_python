        "#| eval: false\n",
        "# Desafío 6: Buscador de archivos\n",
        "# Solución de referencia\n",
        "\n",
        "from pathlib import Path\n",
        "\n",
        "def formatear_tamaño(bytes):\n",
        "    \"\"\"Convierte bytes a formato legible (KB, MB, GB).\"\"\"\n",
        "    if bytes < 1024:\n",
        "        return f\"{bytes} B\"\n",
        "    elif bytes < 1024 * 1024:\n",
        "        return f\"{bytes / 1024:.1f} KB\"\n",
        "    elif bytes < 1024 * 1024 * 1024:\n",
        "        return f\"{bytes / (1024 * 1024):.1f} MB\"\n",
        "    else:\n",
        "        return f\"{bytes / (1024 * 1024 * 1024):.1f} GB\"\n",
        "\n",
        "def buscar_archivos(directorio, extension, texto_busqueda=None):\n",
        "    \"\"\"Busca archivos en un directorio con filtros opcionales.\"\"\"\n",
        "    \n",
        "    directorio = Path(directorio)\n",
        "    \n",
        "    if not directorio.is_dir():\n",
        "        print(f\"❌ '{directorio}' no es un directorio válido\")\n",
        "        return []\n",
        "    \n",
        "    # Construir patrón de búsqueda\n",
        "    if extension == \"*\" or extension == \"\":\n",
        "        patron = \"**/*\"\n",
        "    else:\n",
        "        if not extension.startswith(\".\"):\n",
        "            extension = f\".{extension}\"\n",
        "        patron = f\"**/*{extension}\"\n",
        "    \n",
        "    resultados = []\n",
        "    \n",
        "    for archivo in directorio.glob(patron):\n",
        "        if archivo.is_file():\n",
        "            # Si hay texto de búsqueda, leer el archivo\n",
        "            if texto_busqueda:\n",
        "                try:\n",
        "                    contenido = archivo.read_text(encoding=\"utf-8\")\n",
        "                    if texto_busqueda.lower() in contenido.lower():\n",
        "                        resultados.append(archivo)\n",
        "                except (UnicodeDecodeError, PermissionError):\n",
        "                    continue  # Saltar archivos binarios o sin permiso\n",
        "            else:\n",
        "                resultados.append(archivo)\n",
        "    \n",
        "    return resultados\n",
        "\n",
        "# Programa principal\n",
        "print(\"🔎 === BUSCADOR DE ARCHIVOS ===\\n\")\n",
        "\n",
        "directorio = input(\"Directorio a buscar (. para actual): \").strip() or \".\"\n",
        "extension = input(\"Extensión a buscar (.py, .txt, o * para todos): \").strip()\n",
        "buscar_texto = input(\"Buscar texto dentro de archivos? (s/n): \").strip().lower() == \"s\"\n",
        "\n",
        "texto = None\n",
        "if buscar_texto:\n",
        "    texto = input(\"Texto a buscar: \").strip()\n",
        "\n",
        "print(\"\\n🔍 Buscando...\\n\")\n",
        "\n",
        "resultados = buscar_archivos(directorio, extension, texto)\n",
        "\n",
        "if not resultados:\n",
        "    print(\"❌ No se encontraron archivos\")\n",
        "else:\n",
        "    print(f\"📊 Resultados encontrados: {len(resultados)}\\n\")\n",
        "    \n",
        "    total_bytes = 0\n",
        "    directorio_base = Path(directorio)\n",
        "    \n",
        "    for archivo in sorted(resultados):\n",
        "        tamaño = archivo.stat().st_size\n",
        "        total_bytes += tamaño\n",
        "        ruta_relativa = archivo.relative_to(directorio_base)\n",
        "        \n",
        "        print(f\"  📄 {archivo.name} ({formatear_tamaño(tamaño)})\")\n",
        "        print(f\"     {ruta_relativa}\")\n",
        "        \n",
        "        if texto and texto.lower() in archivo.read_text().lower():\n",
        "            print(f\"     🔍 Contiene: '{texto}'\")\n",
        "        print()\n",
        "    \n",
        "    print(f\"📁 Total: {len(resultados)} archivos | {formatear_tamaño(total_bytes)}\")"
      ],
