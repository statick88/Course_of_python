        "#| eval: false\n",
        "# tareas/interfaz.py\n",
        "def mostrar_menu():\n",
        "    \"\"\"Muestra el menú principal del gestor.\"\"\"\n",
        "    print(\"\\n=== Gestor de Tareas ===\")\n",
        "    print(\"1. Agregar tarea\")\n",
        "    print(\"2. Listar tareas\")\n",
        "    print(\"3. Completar tarea\")\n",
        "    print(\"4. Eliminar tarea\")\n",
        "    print(\"5. Salir\")\n",
        "    print()\n",
        "\n",
        "\n",
        "def mostrar_tareas(tareas):\n",
        "    \"\"\"Muestra todas las tareas con su estado.\"\"\"\n",
        "    if not tareas:\n",
        "        print(\"📋 No hay tareas registradas\")\n",
        "        return\n",
        "\n",
        "    print(\"📋 Tareas:\")\n",
        "    for tarea in tareas:\n",
        "        print(f\"   {tarea}\")\n",
        "        if tarea.descripcion:\n",
        "            print(f\"       📅 {tarea.fecha_creacion} | {tarea.descripcion}\")\n",
        "        else:\n",
        "            print(f\"       📅 {tarea.fecha_creacion}\")\n",
        "\n",
        "\n",
        "def pedir_tarea():\n",
        "    \"\"\"Pide al usuario el título y descripción de una nueva tarea.\"\"\"\n",
        "    titulo = input(\"📝 Título: \").strip()\n",
        "    if not titulo:\n",
        "        return None, None\n",
        "    descripcion = input(\"📝 Descripción: \").strip()\n",
        "    return titulo, descripcion"
