        "#| eval: false\n",
        "# tareas/almacenamiento.py\n",
        "import json\n",
        "from .modelo import Tarea\n",
        "\n",
        "\n",
        "def guardar_tareas(tareas, archivo=\"tareas.json\"):\n",
        "    \"\"\"Guarda la lista de tareas en un archivo JSON.\"\"\"\n",
        "    datos = []\n",
        "    for tarea in tareas:\n",
        "        datos.append({\n",
        "            \"id\": tarea.id,\n",
        "            \"titulo\": tarea.titulo,\n",
        "            \"descripcion\": tarea.descripcion,\n",
        "            \"completada\": tarea.completada,\n",
        "            \"fecha_creacion\": tarea.fecha_creacion,\n",
        "        })\n",
        "    with open(archivo, \"w\", encoding=\"utf-8\") as f:\n",
        "        json.dump(datos, f, indent=2, ensure_ascii=False)\n",
        "\n",
        "\n",
        "def cargar_tareas(archivo=\"tareas.json\"):\n",
        "    \"\"\"Carga las tareas desde un archivo JSON.\"\"\"\n",
        "    try:\n",
        "        with open(archivo, \"r\", encoding=\"utf-8\") as f:\n",
        "            datos = json.load(f)\n",
        "        return [\n",
        "            Tarea(\n",
        "                id=d[\"id\"],\n",
        "                titulo=d[\"titulo\"],\n",
        "                descripcion=d[\"descripcion\"],\n",
        "                completada=d[\"completada\"],\n",
        "                fecha_creacion=d[\"fecha_creacion\"],\n",
        "            )\n",
        "            for d in datos\n",
        "        ]\n",
        "    except FileNotFoundError:\n",
        "        return []\n",
        "    except json.JSONDecodeError:\n",
        "        return []"
      ],
