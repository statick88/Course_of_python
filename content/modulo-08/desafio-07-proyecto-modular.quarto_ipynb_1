        "#| eval: false\n",
        "# tareas/modelo.py\n",
        "from dataclasses import dataclass, field\n",
        "from datetime import datetime\n",
        "\n",
        "\n",
        "@dataclass\n",
        "class Tarea:\n",
        "    \"\"\"Representa una tarea del gestor.\"\"\"\n",
        "    titulo: str\n",
        "    descripcion: str = \"\"\n",
        "    completada: bool = False\n",
        "    fecha_creacion: str = field(default_factory=lambda: datetime.now().strftime(\"%Y-%m-%d\"))\n",
        "    id: int = 0\n",
        "\n",
        "    def toggle(self):\n",
        "        \"\"\"Marca o desmarca la tarea como completada.\"\"\"\n",
        "        self.completada = not self.completada\n",
        "\n",
        "    def __str__(self):\n",
        "        estado = \"✓\" if self.completada else \" \"\n",
        "        return f\"[{estado}] {self.id}. {self.titulo}\""
      ],
