        "#| eval: false\n",
        "# main.py — Programa principal\n",
        "from tareas import Tarea, guardar_tareas, cargar_tareas\n",
        "from tareas import mostrar_menu, mostrar_tareas, pedir_tarea\n",
        "\n",
        "ARCHIVO = \"tareas.json\"\n",
        "\n",
        "def siguiente_id(tareas):\n",
        "    \"\"\"Calcula el siguiente ID disponible.\"\"\"\n",
        "    if not tareas:\n",
        "        return 1\n",
        "    return max(t.id for t in tareas) + 1\n",
        "\n",
        "\n",
        "def main():\n",
        "    \"\"\"Función principal del gestor de tareas.\"\"\"\n",
        "    tareas = cargar_tareas(ARCHIVO)\n",
        "    print(\"=== Gestor de Tareas ===\")\n",
        "\n",
        "    while True:\n",
        "        mostrar_menu()\n",
        "        opcion = input(\"Opción: \").strip()\n",
        "\n",
        "        if opcion == \"1\":\n",
        "            titulo, descripcion = pedir_tarea()\n",
        "            if titulo:\n",
        "                nueva = Tarea(\n",
        "                    id=siguiente_id(tareas),\n",
        "                    titulo=titulo,\n",
        "                    descripcion=descripcion or \"\",\n",
        "                )\n",
        "                tareas.append(nueva)\n",
        "                print(f\"✅ Tarea agregada (ID: {nueva.id})\")\n",
        "            else:\n",
        "                print(\"⚠️  El título no puede estar vacío\")\n",
        "\n",
        "        elif opcion == \"2\":\n",
        "            mostrar_tareas(tareas)\n",
        "\n",
        "        elif opcion == \"3\":\n",
        "            mostrar_tareas(tareas)\n",
        "            try:\n",
        "                id_tarea = int(input(\"🔢 ID de la tarea a completar: \"))\n",
        "                tarea = next((t for t in tareas if t.id == id_tarea), None)\n",
        "                if tarea:\n",
        "                    tarea.toggle()\n",
        "                    estado = \"completada\" if tarea.completada else \"pendiente\"\n",
        "                    print(f\"✅ Tarea {estado}: {tarea.titulo}\")\n",
        "                else:\n",
        "                    print(\"❌ Tarea no encontrada\")\n",
        "            except ValueError:\n",
        "                print(\"❌ Ingresa un número válido\")\n",
        "\n",
        "        elif opcion == \"4\":\n",
        "            mostrar_tareas(tareas)\n",
        "            try:\n",
        "                id_tarea = int(input(\"🔢 ID de la tarea a eliminar: \"))\n",
        "                tarea = next((t for t in tareas if t.id == id_tarea), None)\n",
        "                if tarea:\n",
        "                    tareas.remove(tarea)\n",
        "                    print(f\"🗑️  Tarea eliminada: {tarea.titulo}\")\n",
        "                else:\n",
        "                    print(\"❌ Tarea no encontrada\")\n",
        "            except ValueError:\n",
        "                print(\"❌ Ingresa un número válido\")\n",
        "\n",
        "        elif opcion == \"5\":\n",
        "            guardar_tareas(tareas, ARCHIVO)\n",
        "            print(\"💾 Tareas guardadas. ¡Hasta luego!\")\n",
        "            break\n",
        "\n",
        "        else:\n",
        "            print(\"❌ Opción no válida. Elige 1-5.\")\n",
        "\n",
        "\n",
        "if __name__ == \"__main__\":\n",
        "    main()"
      ],
