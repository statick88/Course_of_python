   "source": [
    "#| eval: false\n",
    "# Desafío 5: Sistema de votaciones\n",
    "# Solución de referencia\n",
    "\n",
    "print(\"=== VOTACIÓN: NUEVO PARQUE DEL BARRIO ===\")\n",
    "print()\n",
    "\n",
    "# Opciones de votación\n",
    "opciones = [\n",
    "    \"Parque del Sol\",\n",
    "    \"Parque de la Luna\",\n",
    "    \"Parque Central\",\n",
    "    \"Parque Esperanza\"\n",
    "]\n",
    "\n",
    "print(\"Opciones:\")\n",
    "for i, opcion in enumerate(opciones, 1):\n",
    "    print(f\"  {i}. {opcion}\")\n",
    "\n",
    "# Simular votos (en un caso real, vendrían de input del usuario)\n",
    "votos = [\n",
    "    \"Parque del Sol\", \"Parque Central\", \"Parque del Sol\",\n",
    "    \"Parque de la Luna\", \"Parque del Sol\", \"Parque Central\",\n",
    "    \"Parque Esperanza\", \"Parque del Sol\", \"Parque de la Luna\",\n",
    "    \"Parque Central\"\n",
    "]\n",
    "\n",
    "print()\n",
    "print(\"--- Registrando votos ---\")\n",
    "print(f\"Votos registrados: {votos}\")\n",
    "\n",
    "# Contar votos\n",
    "conteo = {opcion: 0 for opcion in opciones}  # Inicializar en 0\n",
    "for voto in votos:\n",
    "    if voto in conteo:\n",
    "        conteo[voto] += 1\n",
    "\n",
    "# Ordenar resultados\n",
    "resultados = sorted(conteo.items(), key=lambda x: x[1], reverse=True)\n",
    "\n",
    "# Mostrar resultados\n",
    "print()\n",
    "print(\"--- Resultados ---\")\n",
    "medallas = [\"🥇\", \"🥈\", \"🥉\", \"   \", \"   \"]\n",
    "total_votos = len(votos)\n",
    "\n",
    "for i, (opcion, cantidad) in enumerate(resultados):\n",
    "    porcentaje = (cantidad / total_votos) * 100 if total_votos > 0 else 0\n",
    "    medalla = medallas[i] if i < len(medallas) else \"   \"\n",
    "    print(f\"{medalla} {opcion}: {cantidad} votos ({porcentaje:.1f}%)\")\n",
    "\n",
    "print()\n",
    "print(f\"--- Total de votos: {total_votos} ---\")\n",
    "\n",
    "# Declarar ganador\n",
    "ganador, votos_ganador = resultados[0]\n",
    "segundo = resultados[1]\n",
    "\n",
    "if votos_ganador == segundo[1]:\n",
    "    print()\n",
    "    print(\"🤝 ¡EMPATE! Hay dos opciones con la misma cantidad de votos.\")\n",
    "else:\n",
    "    print()\n",
    "    print(f\"🏆 ¡GANADOR: {ganador} con {votos_ganador} votos!\")"
   ]
