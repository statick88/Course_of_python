   "outputs": [],
   "source": [
    "#| eval: false\n",
    "# Desafío 2: Calculadora de edad\n",
    "# Solución de referencia\n",
    "\n",
    "anio_actual = 2026\n",
    "\n",
    "print(\"=== CALCULADORA DE EDAD — HOSPITAL ===\")\n",
    "print()\n",
    "\n",
    "nombre = input(\"Nombre del paciente: \").strip()\n",
    "edad = int(input(\"Edad actual: \"))\n",
    "\n",
    "anio_nacimiento = anio_actual - edad\n",
    "es_mayor = edad >= 18\n",
    "edad_futura = edad + 10\n",
    "\n",
    "print()\n",
    "print(\"--- Ficha del paciente ---\")\n",
    "print(f\"Paciente: {nombre}\")\n",
    "print(f\"Edad actual: {edad} años\")\n",
    "print(f\"Año de nacimiento (aprox.): {anio_nacimiento}\")\n",
    "print(f\"¿Es mayor de edad?: {'Sí' if es_mayor else 'No'}\")\n",
    "print(f\"Edad en 10 años: {edad_futura} años\")"
   ]
