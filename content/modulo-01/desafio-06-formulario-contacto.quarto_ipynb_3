   "metadata": {},
   "outputs": [],
   "source": [
    "#| eval: false\n",
    "# Desafío 6: Formulario de contacto\n",
    "# Solución de referencia\n",
    "\n",
    "print(\"=== FORMULARIO DE CONTACTO ===\")\n",
    "print()\n",
    "\n",
    "# Validar nombre\n",
    "while True:\n",
    "    nombre = input(\"Nombre completo: \").strip()\n",
    "    if len(nombre) >= 3:\n",
    "        break\n",
    "    print(\"Error: El nombre debe tener al menos 3 caracteres\")\n",
    "\n",
    "# Validar email\n",
    "while True:\n",
    "    email = input(\"Correo electrónico: \").strip()\n",
    "    if \"@\" in email and \".\" in email:\n",
    "        break\n",
    "    print(\"Error: El correo debe contener '@' y '.'\")\n",
    "\n",
    "# Validar teléfono\n",
    "while True:\n",
    "    telefono = input(\"Teléfono: \").strip()\n",
    "    if telefono.isdigit() and 7 <= len(telefono) <= 15:\n",
    "        break\n",
    "    print(\"Error: El teléfono solo debe contener números (7-15 dígitos)\")\n",
    "\n",
    "# Validar edad\n",
    "while True:\n",
    "    try:\n",
    "        edad = int(input(\"Edad: \"))\n",
    "        if 18 <= edad <= 120:\n",
    "            break\n",
    "        print(\"Error: Debes ser mayor de 18 años\")\n",
    "    except ValueError:\n",
    "        print(\"Error: Ingresa un número válido\")\n",
    "\n",
    "# Resumen\n",
    "print()\n",
    "print(\"--- Datos registrados ---\")\n",
    "print(f\"Nombre:     {nombre}\")\n",
    "print(f\"Email:      {email}\")\n",
    "print(f\"Teléfono:   {telefono}\")\n",
    "print(f\"Edad:       {edad} años\")\n",
    "print()\n",
    "# Extraer el primer nombre para el saludo\n",
    "primer_nombre = nombre.split()[0]\n",
    "print(f\"¡Gracias por registrarte, {primer_nombre}!\")"
   ]
